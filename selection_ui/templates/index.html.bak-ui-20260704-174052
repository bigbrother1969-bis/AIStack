<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ definition.title }}</title>
  <style>
    body { font-family: sans-serif; max-width: 1000px; margin: 2rem auto; }
    header { margin-bottom: 1.5rem; }
    .meta { color: #555; margin-bottom: 1rem; }
    .toolbar { margin: 1rem 0; }
    input[type="search"] { width: 100%; padding: .6rem; font-size: 1rem; }
    .item { padding: .35rem 0; border-bottom: 1px solid #eee; }
    button { margin-top: 1rem; padding: .7rem 1.2rem; font-size: 1rem; }
  </style>
</head>
<body>
  <header>
    <h1>{{ definition.title }}</h1>
    <div class="meta">
      Catalog: {{ catalog.catalog_id }} —
      Items: {{ catalog.items|length }} —
      Selected: {{ selected|length }}
    </div>
  </header>

  <div class="toolbar">
    <input type="search" id="filter" placeholder="Filter items..." onkeyup="filterItems()">
  </div>

  <form method="post" action="/save">
    <button type="submit">Save selection and regenerate</button>

    <div id="items">
      {% for item in catalog.items %}
        <div class="item" data-label="{{ item.label|lower }}">
          <label>
            <input type="checkbox" name="selected_ids" value="{{ item.id }}"
              {% if item.id in selected %}checked{% endif %}>
            {{ item.label }}
          </label>
        </div>
      {% endfor %}
    </div>

    <button type="submit">Save selection and regenerate</button>
  </form>

  <script>
    function filterItems() {
      const q = document.getElementById("filter").value.toLowerCase();
      document.querySelectorAll(".item").forEach(el => {
        el.style.display = el.dataset.label.includes(q) ? "" : "none";
      });
    }
  </script>
</body>
</html>
